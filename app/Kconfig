# This file is the application Kconfig entry point. All application Kconfig
# options can be defined here or included via other application Kconfig files.
# You can browse these options using the west targets menuconfig (terminal) or
# guiconfig (GUI).

menu "Zephyr"
source "Kconfig.zephyr"
endmenu

menu "WebOS"

config WEBOS_WIFI_SSID
	string "Wi-Fi SSID"
	default ""

config WEBOS_WIFI_PSK
	string "Wi-Fi PSK"
	default ""

config WEBOS_LOG_BUFFER
	bool "Enable WebOS log buffer for webdb log command"
	select LOG_OUTPUT
	help
	  In-memory ring buffer that captures Zephyr log output
	  for retrieval via HTTP POST /log.  Adds a log backend
	  that mirrors every LOG_* call into a mutable buffer.

if WEBOS_LOG_BUFFER

config WEBOS_LOG_BUFFER_SIZE
	int "Ring buffer size in bytes"
	default 4096
	range 1024 65536

config WEBOS_LOG_BACKEND_BUF_SIZE
	int "Log backend output buffer size"
	default 256

config WEBOS_LOG_BACKEND_OUTPUT_DEFAULT
	int "Default log output format"
	default 0

endif

config WEBOS_SSH
	bool "Enable SSH shell server"
	default n
	select DNS_RESOLVER
	select SSH_SERVER
	select SHELL_BACKEND_SSH
	help
	  Enable the SSH shell server. Disabled by default because the SSH stack is
	  memory-heavy on the ESP32-S3 target.

config WEBOS_SSH_USERNAME
	string "SSH username"
	default "root"
	depends on WEBOS_SSH

config WEBOS_SSH_PASSWORD
	string "SSH password"
	default "1"
	depends on WEBOS_SSH

endmenu

module = APP
module-str = APP
source "subsys/logging/Kconfig.template.log_config"
