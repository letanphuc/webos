# Source this file from webos/app: . ./.env

export WEBOS_BOARD="${WEBOS_BOARD:-esp32s3_devkitm/esp32s3/procpu}"
export WEBOS_BUILD_DIR="${WEBOS_BUILD_DIR:-build}"
export WEBOS_APP_DIR="${WEBOS_APP_DIR:-$(pwd)}"

# Zephyr maps esp32s3_devkitm/esp32s3/procpu to esp32s3_devkitc/esp32s3/procpu.

build() {
	west build -b "$WEBOS_BOARD" "$WEBOS_APP_DIR" -d "$WEBOS_BUILD_DIR" "$@"
}

rebuild() {
	west build -p always -b "$WEBOS_BOARD" "$WEBOS_APP_DIR" -d "$WEBOS_BUILD_DIR" "$@"
}

flash() {
	west flash -d "$WEBOS_BUILD_DIR" "$@"
}

run() {
	west build -b "$WEBOS_BOARD" "$WEBOS_APP_DIR" -d "$WEBOS_BUILD_DIR" "$@" && west flash -d "$WEBOS_BUILD_DIR"
}

menuconfig() {
	west build -t menuconfig -d "$WEBOS_BUILD_DIR"
}

clean() {
	rm -rf "$WEBOS_BUILD_DIR"
}

twister_app() {
	west twister -T "$WEBOS_APP_DIR" -v --inline-logs --integration "$@"
}
