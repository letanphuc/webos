# Source this file from webos/app: . ./.env

export WEBOS_BOARD="${WEBOS_BOARD:-webos_esp32s3/esp32s3/procpu}"
export WEBOS_ROOT="${WEBOS_ROOT:-$(cd ../.. && pwd)}"
export WEBOS_BUILD_DIR="${WEBOS_BUILD_DIR:-$WEBOS_ROOT/build}"
export WEBOS_APP_DIR="${WEBOS_APP_DIR:-$WEBOS_ROOT/webos/app}"
export WEBOS_PORT="${WEBOS_PORT:-/dev/tty.usbserial-1130}"
export WEBOS_BAUD="${WEBOS_BAUD:-460800}"
export USE_CCACHE="${USE_CCACHE:-1}"

# Zephyr maps esp32s3_devkitm/esp32s3/procpu to esp32s3_devkitc/esp32s3/procpu.

extra_args=(-DUSE_CCACHE="$USE_CCACHE" -DEXTRA_CONF_FILE="wifi.conf")

build() {
	west build --sysbuild -b "$WEBOS_BOARD" "$WEBOS_APP_DIR" -d "$WEBOS_BUILD_DIR" "$@" -- "${extra_args[@]}"
}

rebuild() {
	west build --sysbuild -p always -b "$WEBOS_BOARD" "$WEBOS_APP_DIR" -d "$WEBOS_BUILD_DIR" "$@" -- "${extra_args[@]}"
}

flash() {
	west flash -d "$WEBOS_BUILD_DIR" --esp-device "$WEBOS_PORT" --esp-baud-rate "$WEBOS_BAUD" "$@"
}

run() {
	build "$@" && flash
}

monitor() {
	west espressif monitor -p "$WEBOS_PORT" -e "$WEBOS_BUILD_DIR/app/zephyr/zephyr.elf" "$@"
}

menuconfig() {
	west build -t menuconfig -d "$WEBOS_BUILD_DIR"
}

clean() {
	rm -rf "$WEBOS_BUILD_DIR"
}

twister_app() {
	west twister -T "$WEBOS_APP_DIR" -v --inline-logs --integration "$@"
}

formatcode() {
	find "$WEBOS_ROOT/webos" \
		\( -path "$WEBOS_ROOT/webos/build" -o -path "$WEBOS_ROOT/webos/.west" -o -path "$WEBOS_ROOT/webos/.git" \) -prune -o \
		\( -name '*.c' -o -name '*.h' -o -name '*.cc' -o -name '*.hh' -o -name '*.cpp' -o -name '*.hpp' -o -name '*.cxx' -o -name '*.hxx' \) \
		-print0 | xargs -0 clang-format -i
}
