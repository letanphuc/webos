config WEBOS_RGBLED
	bool "WebOS RGB LED strip devfs wrapper"
	depends on WEBOS_DEVFS
	depends on LED_STRIP
	help
	  Register webos,rgbled devicetree nodes as /dev/rgbled/<n>/color files.

config WEBOS_RGBLED_MAX_PIXELS
	int "Maximum pixels updated by each WebOS RGB LED node"
	depends on WEBOS_RGBLED
	default 8
	help
	  Upper bound for stack pixel buffers used when mirroring one color across
	  the referenced Zephyr LED strip.
